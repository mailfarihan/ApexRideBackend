# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/apexride?retryWrites=true&w=majority

# Server port
PORT=3000

# Firebase Admin (for verifying auth tokens)
# Download from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_PROJECT_ID=apexride-9bdff

# Firebase service account JSON (for Storage access)
# Paste the entire JSON as a single line, or set in Render env vars
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"apexride-9bdff",...}

# Google Static Maps API key (for generating map preview images)
GOOGLE_STATIC_MAPS_API_KEY=your-google-static-maps-api-key
